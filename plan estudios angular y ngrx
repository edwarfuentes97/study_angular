#### P5: ¿Cómo implementas Effects para llamadas HTTP?
**Respuesta esperada:**
```typescript
@Injectable()
export class ProductEffects {
  loadProducts$ = createEffect(() =>
    this.actions$.pipe(
      ofType(ProductActions.loadProducts),
      // switchMap cancela peticiones anteriores (útil para búsqueda)
      // exhaustMap ignora nuevas mientras la actual esté activa (útil para submit)
      // concatMap ejecuta secuencialmente (útil para orden importa)
      // mergeMap ejecuta en paralelo (útil para operaciones independientes)
      switchMap(() =>
        this.productService.getAll().pipe(
          map(products => ProductActions.loadProductsSuccess({ products })),
          catchError(error =>
            of(ProductActions.loadProductsFailure({ error: error.message }))
          )
        )
      )
    )
  );

  constructor(
    private actions$: Actions,
    private productService: ProductService
  ) {}
}
```

